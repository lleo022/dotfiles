// Niri Configuration (KDL format: https://kdl.dev)
// Documentation: https://yalter.github.io/niri/Configuration:-Introduction

// --- STARTUP & ENVIRONMENT ---
environment {
    GNOME_KEYRING_CONTROL "/run/user/1000/keyring"
    QT_QPA_PLATFORMTHEME "qt6ct"
}

// Spawn processes on startup
spawn-at-startup "xwayland-satellite"
spawn-sh-at-startup "qs -c ~/noctalia-shell" // Noctalia Shell
spawn-sh-at-startup "gnome-keyring-daemon --start --components=secrets,ssh,pkcs11" // Gnome Keyring for VSCode
spawn-sh-at-startup "env XDG_MENU_PREFIX=arch- kbuildsycoca6"
// Note that running niri as a session supports xdg-desktop-autostart,
// which may be more convenient to use.

hotkey-overlay {
    skip-at-startup // Hide "Important Hotkeys" pop-up on start
}


// --- INPUT DEVICE CONFIGURATION ---
// https://yalter.github.io/niri/Configuration:-Input
input {
    keyboard {
        xkb {
            // Options: layout "us,ru", options "grp:win_space_toggle,compose:ralt,ctrl:nocaps"
            // For more info, see xkeyboard-config(7)
            // If empty, niri will fetch xkb settings from org.freedesktop.locale1.
            // Control these using localectl set-x11-remap
        }

        numlock // Enable numlock on startup. Omitting disables it.
    }

    // Uses libinput settings.
    touchpad {
        tap
        dwt // disable-while-typing
        natural-scroll

        // dwtp // disable-when-trackpoint
        // drag false
        // drag-lock
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
        // natural-scroll
    }

    trackpoint {
        // natural-scroll
        // scroll-method "on-button-down"
    }

    // Warp cursor to center of newly focused windows
    // warp-mouse-to-focus 

    // Focus windows and outputs automatically when moving the mouse into them.
    // Setting max-scroll-amount="0%" makes it work only on windows already fully on screen.
    // focus-follows-mouse max-scroll-amount="0%"  
}


// --- OUTPUT & DISPLAY ---
// Find output names via `niri msg outputs` (e.g., "eDP-1")
// https://yalter.github.io/niri/Configuration:-Outputs
output "eDP-2" {
    mode "2560x1600@240.000" // Format: "<width>x<height>@<refresh rate>". FPS defaults to highest.
    scale 1.5 // Use interger or fractional scale (1.5 == 150%).
    transform "normal" // Rotate the output counter-clockwise (normal, 90, 180, 270, flipped, flipped-90, flipped-180 and flipped-270).
    position x=0 y=0 // Position of the output in the global coordinate space.
}

// https://yalter.github.io/niri/Configuration:-Animations
animations {
    // slowdown 3.0 // Slow down all animations by this factor
}

// Request apps to omit client-side decorations (CSD)
// Removes client-side rounded corners and improves border rendering.
prefer-no-csd

// Path for screenshots (strftime(3) format supported)
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
// screenshot-path null // Disable saving screenshots to disk.


// --- WINDOW LAYOUT & DECORATIONS ---
// https://yalter.github.io/niri/Configuration:-Layout
layout {
    gaps 16 // Set gaps around windows in logical pixels..
    center-focused-column "never" // Options: "never", "always", "on-overflow"

    // Customize the widths that "switch-preset-column-width" (Mod+R) toggles between.
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    // Customize the heights that "switch-preset-window-height" (Mod+Shift+R) toggles between.
    // preset-window-heights { }

    // You can change the default width of the new windows.
    default-column-width { proportion 0.5; }

    // Visual indicators for focused/active windows
    focus-ring {
        // off
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
        // Gradients take precedence over solid colors
        // active-gradient from="#80c8ff" to="#c7ff7f" angle=45
        // inactive-gradient from="#505050" to="#808080" angle=45 relative-to="workspace-view"
    }

    border { // same settings as focus-ring
        off // Enable border to always see window edges (similar to focus-ring)
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    shadow {
        // on
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
        // draw-behind-window true // Useful if CSD artifacts appear
    }

    struts {
        // Outer gaps in logical pixels (left, right, top, bottom)
    }
}


// --- WINDOW RULES ---
// https://yalter.github.io/niri/Configuration:-Window-Rules
// Rule for WezTerm to fix initial configuration bugs
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Media & Floating rules for Firefox
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// App sizing rules
window-rule {
    match app-id=r#"firefox$"#  // Firefox
    match app-id="^code$"       // VSCode
    match app-id="^obsidian$"   // Obsidian
    match app-id="Unity"        // Unity Editor
    default-column-width { proportion 1.0; }
}

window-rule {
    match app-id="^discord$"    // Discord
    match app-id="^Slack$"      // Slack
    match app-id="^Spotify$"    // Spotify
    match app-id="^steam$"      // Steam
    default-column-width { proportion 0.8; }
}

// Privacy rules
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    match app-id=r#"^bitwarden$"#
    block-out-from "screen-capture"
    // block-out-from "screencast"
}

// General aesthetics
window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}


// --- KEYBINDS ---
binds {
    // #"APPLICATIONS"
    Mod+Return hotkey-overlay-title="Terminal" { spawn "kitty"; }
    Mod+Space hotkey-overlay-title="App Launcher" { spawn-sh "qs -c ~/noctalia-shell ipc call launcher toggle"; }
    Mod+Shift+W hotkey-overlay-title="Wallpaper Selector" { spawn-sh "qs -c ~/noctalia-shell ipc call wallpaper toggle"; }
    Mod+Shift+Slash hotkey-overlay-title="Keybinds List" { spawn-sh "qs -c ~/noctalia-shell ipc call plugin:keybind-cheatsheet toggle"; }
    Mod+E hotkey-overlay-title="File Manager" { spawn "dolphin"; }


    // #"SYSTEM"
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Lock Screen" { spawn-sh "qs -c ~/noctalia-shell ipc call lockScreen lock"; }
    Mod+M hotkey-overlay-title="Power Menu" { spawn-sh "qs -c ~/noctalia-shell ipc call sessionMenu toggle"; }
    Mod+Shift+M hotkey-overlay-title="Quit" { quit; }
    Ctrl+Alt+Delete hotkey-overlay-title="Quit" { quit; }
    Mod+Shift+P hotkey-overlay-title="Power Off Monitors" { power-off-monitors; } // Interact to turn back on.
    // Mod+Alt+S allow-when-locked=true hotkey-overlay-title="Toggle Screen Reader" { spawn-sh "pkill orca || exec orca"; }
    Mod+Shift+Escape hotkey-overlay-title="Toggle Shortcut Inhibit" allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    

    // --- Hardware Keys ---
    // Volume keys mappings for PipeWire & WirePlumber.
    // The allow-when-locked=true property makes them work even when the session is locked.
    // `-l 1.0` limits the volume to 100%.
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title=null { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title=null { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true hotkey-overlay-title=null { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true hotkey-overlay-title=null { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // Media keys mapping using playerctl.
    // This will work with any MPRIS-enabled media player.
    XF86AudioPlay        allow-when-locked=true hotkey-overlay-title=null { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true hotkey-overlay-title=null { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true hotkey-overlay-title=null { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true hotkey-overlay-title=null { spawn-sh "playerctl next"; }

    // Brightness key mappings for brightnessctl.
    XF86MonBrightnessUp   allow-when-locked=true hotkey-overlay-title=null { spawn-sh "brightnessctl -d amdgpu_bl2 set +5%"; }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title=null { spawn-sh "brightnessctl -d amdgpu_bl2 set 5%-"; }


    // #"WINDOW MANAGEMENT"
    Mod+Q repeat=false hotkey-overlay-title="Close Window" { close-window; }
    Mod+F hotkey-overlay-title="Maximize" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Fullscreen" { fullscreen-window; }
    // Expand the focused column to space not taken up by other fully visible columns.
    // Makes the column "fill the rest of the space".
    Mod+Ctrl+F hotkey-overlay-title="Expand Column" { expand-column-to-available-width; }
    Mod+V hotkey-overlay-title="Toggle Floating" { toggle-window-floating; }
    Mod+Shift+V hotkey-overlay-title="Swap Floating / Tiling Focus" { switch-focus-between-floating-and-tiling; }
    // Toggle tabbed column display mode.
    // Windows in this column will appear as vertical tabs, rather than stacked on top of each other.
    Mod+W hotkey-overlay-title="Toggle Tabbed Column" { toggle-column-tabbed-display; }
    // The following binds move the focused window in and out of a column.
    // If the window is alone, they will consume it into the nearby column to the side.
    // If the window is already in a column, they will expel it out.
    Mod+BracketLeft  hotkey-overlay-title="Consume / Expel Left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Consume / Expel Right" { consume-or-expel-window-right; }
    // Consume one window from the right to the bottom of the focused column.
    Mod+Comma  hotkey-overlay-title="Consume Window into Column" { consume-window-into-column; }
    // Expel the bottom window from the focused column to the right.
    Mod+Period hotkey-overlay-title="Expel Window from Column" { expel-window-from-column; }
    

    // #"LAYOUT & SIZING"
    Mod+C hotkey-overlay-title="Center Column" { center-column; }
    Mod+Ctrl+C hotkey-overlay-title="Center Visible Columns" { center-visible-columns; }
    // Cycle through preset column widths (1/3, 1/2, 2/3).
    Mod+R hotkey-overlay-title="Cycle Column Width" { switch-preset-column-width; }
    // Cycling through the presets in reverse order is also possible.
    // Mod+R { switch-preset-column-width-back; }
    Mod+Shift+R hotkey-overlay-title="Cycle Window Height" { switch-preset-window-height; }
    Mod+Ctrl+R hotkey-overlay-title="Reset Window Height" { reset-window-height; }
    Mod+Minus       hotkey-overlay-title="Column Width -10%" { set-column-width "-10%"; }
    Mod+Equal       hotkey-overlay-title="Column Width +10%" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Window Height -10%" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Window Height +10%" { set-window-height "+10%"; }

    // Finer width adjustments.
    // This command can also:
    // * set width in pixels: "1000"
    // * adjust width in pixels: "-5" or "+5"
    // * set width as a percentage of screen width: "25%"
    // * adjust width as a percentage of screen width: "-10%" or "+10%"
    // Pixel sizes use logical, or scaled, pixels. I.e. on an output with scale 2.0,
    // set-column-width "100" will make the column occupy 200 physical screen pixels.

    // Actions to switch layouts.
    // Note: if you uncomment these, make sure you do NOT have
    // a matching layout switch hotkey configured in xkb options above.
    // Having both at once on the same hotkey will break the switching,
    // since it will switch twice upon pressing the hotkey (once by xkb, once by niri).
    // Mod+Space       { switch-layout "next"; }
    // Mod+Shift+Space { switch-layout "prev"; }


    // #"FOCUS NAVIGATION (Arrows + IJKL)"
    Mod+Tab   hotkey-overlay-title="Toggle Overview" repeat=false { toggle-overview; }
    Mod+Up    hotkey-overlay-title=null { focus-window-up; }
    Mod+I     hotkey-overlay-title="Focus Up" { focus-window-up; }
    Mod+Down  hotkey-overlay-title=null { focus-window-down; }
    Mod+K     hotkey-overlay-title="Focus Down" { focus-window-down; }
    Mod+Left  hotkey-overlay-title=null { focus-column-left; }
    Mod+J     hotkey-overlay-title="Focus Left" { focus-column-left; }
    Mod+Right hotkey-overlay-title=null { focus-column-right; }
    Mod+L     hotkey-overlay-title="Focus Right" { focus-column-right; }
    
    Mod+Home  hotkey-overlay-title="Focus First" { focus-column-first; }
    Mod+End   hotkey-overlay-title="Focus Last" { focus-column-last; }

    // Scrolling
    Mod+WheelScrollRight           hotkey-overlay-title=null { focus-column-right; }
    Mod+WheelScrollLeft            hotkey-overlay-title=null { focus-column-left; }
    Mod+Shift+WheelScrollUp        hotkey-overlay-title="Focus Left" { focus-column-left; }
    Mod+Shift+TouchpadScrollUp     hotkey-overlay-title=null { focus-column-left; }
    Mod+Shift+WheelScrollDown      hotkey-overlay-title="Focus Right" { focus-column-right; }
    Mod+Shift+TouchpadScrollDown   hotkey-overlay-title=null { focus-column-right; }

    // Alternative commands that move across workspaces when reaching
    // the first or last window in a column.
    // Mod+I { focus-window-or-workspace-up; }
    // Mod+K { focus-window-or-workspace-down; }


    // #"MOVING WINDOWS (Arrows + IJKL)"
    Mod+Shift+Up    hotkey-overlay-title=null { move-window-up; }
    Mod+Shift+I     hotkey-overlay-title="Move Up" { move-window-up; }
    Mod+Shift+Down  hotkey-overlay-title=null { move-window-down; }
    Mod+Shift+K     hotkey-overlay-title="Move Down" { move-window-down; }
    Mod+Shift+Left  hotkey-overlay-title=null { move-column-left; }
    Mod+Shift+J     hotkey-overlay-title="Move Left" { move-column-left; }
    Mod+Shift+Right hotkey-overlay-title=null { move-column-right; }
    Mod+Shift+L     hotkey-overlay-title="Move Right" { move-column-right; }
    
    Mod+Shift+Home  hotkey-overlay-title="Move to First" { move-column-to-first; }
    Mod+Shift+End   hotkey-overlay-title="Move to Last" { move-column-to-last; }
    
    // Scrolling
    Mod+Ctrl+WheelScrollRight         hotkey-overlay-title=null { move-column-right; }
    Mod+Ctrl+WheelScrollLeft          hotkey-overlay-title=null { move-column-left; }
    Mod+Ctrl+Shift+WheelScrollUp      hotkey-overlay-title="Move Left" { move-column-left; }
    Mod+Ctrl+Shift+TouchpadScrollUp   hotkey-overlay-title=null { move-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown    hotkey-overlay-title="Move Right" { move-column-right; }
    Mod+Ctrl+Shift+TouchpadScrollDown hotkey-overlay-title=null { move-column-right; }

    // Alternatively, there are commands to move just a single window:
    // Mod+Ctrl+J { move-window-down-or-to-workspace-down; }
    // Mod+Ctrl+K { move-window-up-or-to-workspace-up; }


    // --- Monitor Management (uncomment for multi-monitor setups) ---
    // Mod+Ctrl+Left  { focus-monitor-left; }
    // Mod+Ctrl+Down  { focus-monitor-down; }
    // Mod+Ctrl+Up    { focus-monitor-up; }
    // Mod+Ctrl+Right { focus-monitor-right; }
    //
    // Mod+Ctrl+Shift+Left  { move-column-to-monitor-left; }
    // Mod+Ctrl+Shift+Down  { move-column-to-monitor-down; }
    // Mod+Ctrl+Shift+Up    { move-column-to-monitor-up; }
    // Mod+Ctrl+Shift+Right { move-column-to-monitor-right; }
    //
    // Alternatively, there are commands to move just a single window:
    // Mod+Ctrl+Shift+Left  { move-window-to-monitor-left; }
    // ...
    //
    // And you can also move a whole workspace to another monitor:
    // Mod+Ctrl+Shift+Left  { move-workspace-to-monitor-left; }
    // ...

    
    // #"WORKSPACES"
    // Focus workspace by index (best effort)
    Mod+1 hotkey-overlay-title="Workspace 1" { focus-workspace 1; }
    Mod+2 hotkey-overlay-title="Workspace 2" { focus-workspace 2; }
    Mod+3 hotkey-overlay-title="Workspace 3" { focus-workspace 3; }
    Mod+4 hotkey-overlay-title="Workspace 4" { focus-workspace 4; }
    Mod+5 hotkey-overlay-title=null { focus-workspace 5; }
    Mod+6 hotkey-overlay-title=null { focus-workspace 6; }
    Mod+7 hotkey-overlay-title=null { focus-workspace 7; }
    Mod+8 hotkey-overlay-title=null { focus-workspace 8; }
    Mod+9 hotkey-overlay-title=null { focus-workspace 9; }

    // Focus workspace by direction (Page keys + U/O keys + Scroll)
    Mod+U         hotkey-overlay-title="Previous Workspace" { focus-workspace-up; }
    Mod+O         hotkey-overlay-title="Next Workspace" { focus-workspace-down; }
    Mod+Page_Up   hotkey-overlay-title=null { focus-workspace-up; }
    Mod+Page_Down hotkey-overlay-title=null { focus-workspace-down; }
    Mod+WheelScrollUp         cooldown-ms=150 hotkey-overlay-title="Previous Workspace" { focus-workspace-up; }
    Mod+WheelScrollDown       cooldown-ms=150 hotkey-overlay-title="Next Workspace" { focus-workspace-down; }
    Mod+TouchpadScrollUp      cooldown-ms=150 hotkey-overlay-title=null { focus-workspace-up; }
    Mod+TouchpadScrollDown    cooldown-ms=150 hotkey-overlay-title=null { focus-workspace-down; }

    // Move column to workspace by index
    Mod+Shift+1 hotkey-overlay-title="Send to Workspace 1" { move-column-to-workspace 1; }
    Mod+Shift+2 hotkey-overlay-title="Send to Workspace 2" { move-column-to-workspace 2; }
    Mod+Shift+3 hotkey-overlay-title="Send to Workspace 3" { move-column-to-workspace 3; }
    Mod+Shift+4 hotkey-overlay-title="Send to Workspace 4" { move-column-to-workspace 4; }
    Mod+Shift+5 hotkey-overlay-title=null { move-column-to-workspace 5; }
    Mod+Shift+6 hotkey-overlay-title=null { move-column-to-workspace 6; }
    Mod+Shift+7 hotkey-overlay-title=null { move-column-to-workspace 7; }
    Mod+Shift+8 hotkey-overlay-title=null { move-column-to-workspace 8; }
    Mod+Shift+9 hotkey-overlay-title=null { move-column-to-workspace 9; }

    // Move column to workspace by direction (Page keys + U/O keys + Scroll)
    Mod+Ctrl+U         hotkey-overlay-title="Send to Previous Workspace" { move-column-to-workspace-up; }
    Mod+Ctrl+O         hotkey-overlay-title="Send to Next Workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   hotkey-overlay-title=null { move-column-to-workspace-up; }
    Mod+Ctrl+Page_Down hotkey-overlay-title=null { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp    cooldown-ms=150 hotkey-overlay-title="Send to Previous Workspace" { move-column-to-workspace-up; }
    Mod+Ctrl+WheelScrollDown  cooldown-ms=150 hotkey-overlay-title="Send to Next Workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+TouchpadScrollUp    cooldown-ms=150 hotkey-overlay-title=null { move-column-to-workspace-up; }
    Mod+Ctrl+TouchpadScrollDown  cooldown-ms=150 hotkey-overlay-title=null { move-column-to-workspace-down; }

    // Reorder Workspaces
    Mod+Shift+U         hotkey-overlay-title="Reorder Workspace Up" { move-workspace-up; }
    Mod+Shift+O         hotkey-overlay-title="Reorder Workspace Down" { move-workspace-down; }
    Mod+Shift+Page_Up   hotkey-overlay-title=null { move-workspace-up; }
    Mod+Shift+Page_Down hotkey-overlay-title=null { move-workspace-down; }

    // Switches focus between the current and the previous workspace.
    // Mod+Tab { focus-workspace-previous; }

    // Alternatively, there are commands to move just a single window:
    // Mod+Ctrl+Page_Down { move-window-to-workspace-down; }
    // Mod+Shift+1 { move-window-to-workspace 1; }


    // #"SCREENSHOTS"
    Mod+Shift+S hotkey-overlay-title="Screenshot"        { screenshot; }
    Mod+Ctrl+S  hotkey-overlay-title="Screenshot Screen" { screenshot-screen; }
    Mod+Alt+S   hotkey-overlay-title="Screenshot Window" { screenshot-window; }
   
}

// --- MISC ---
debug {
    render-drm-device "/dev/dri/renderD129"
    ignore-drm-device "/dev/dri/renderD128"
}

gestures {
    hot-corners { 
        off 
    }
}

include "./noctalia.kdl"

